{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@hu-partner/types": ["./packages/types/src/index.ts"],
      "@hu-partner/utils": ["./packages/utils/src/index.ts"],
      "@hu-partner/ui": ["./packages/ui/src/index.ts"],
      "@hu-partner/config": ["./packages/config"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}
