# ─── Web Application Environment ───

# API endpoint for server-side and client-side requests
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Public-facing application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# S3/CloudFront URL for media assets
NEXT_PUBLIC_S3_URL=https://your-bucket.s3.amazonaws.com

# Used in next.config.ts to determine if the build output should be standalone (for Docker/custom deployments) or standard (if      
#   deployed on Vercel). This is usually injected automatically by Vercel, but good to know for testing/Docker setups. 
VERCEL = standard

# Environment context ( development ,  test , or  production ).
NODE_ENV =  development