generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  ADMIN
  EDITOR
  BRAND_MANAGER
  VIEWER
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  name         String
  role         UserRole    @default(VIEWER)
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  auditLogs    AuditLog[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  refreshTokenHash String
  expiresAt        DateTime
  userAgent        String?
  ipAddress        String?
  createdAt        DateTime @default(now())

  @@map("sessions")
}

model Category {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  description String?
  partners    Partner[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@map("categories")
}

model MediaAsset {
  id          String    @id @default(uuid())
  key         String    @unique // S3 Key
  url         String
  mimeType    String
  sizeBytes   Int
  altText     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relations
  partnerLogos    Partner[]         @relation("PartnerLogo")
  partnerHeroes   Partner[]         @relation("PartnerHero")
  newsletterIssues NewsletterIssue[] @relation("IssuePDF")

  @@map("media_assets")
}

model Partner {
  id          String        @id @default(uuid())
  slug        String        @unique
  name        String
  description String
  website     String?
  status      ContentStatus @default(DRAFT)
  featured    Boolean       @default(false)
  tier        String?
  
  // Relations
  categories  Category[]
  offers      Offer[]
  
  logoId      String?
  logo        MediaAsset?   @relation("PartnerLogo", fields: [logoId], references: [id])
  heroId      String?
  hero        MediaAsset?   @relation("PartnerHero", fields: [heroId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@map("partners")
}

model Offer {
  id            String        @id @default(uuid())
  partnerId     String
  partner       Partner       @relation(fields: [partnerId], references: [id])
  title         String
  description   String
  code          String?
  discountType  String
  discountValue Float
  startDate     DateTime?
  endDate       DateTime?
  terms         String?
  status        ContentStatus @default(DRAFT)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt   DateTime?

  @@map("offers")
}

model Newsletter {
  id          String            @id @default(uuid())
  slug        String            @unique
  title       String
  description String?
  status      ContentStatus     @default(DRAFT)
  issues      NewsletterIssue[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  @@map("newsletters")
}

model NewsletterIssue {
  id           String        @id @default(uuid())
  newsletterId String
  newsletter   Newsletter    @relation(fields: [newsletterId], references: [id])
  slug         String        @unique
  title        String
  excerpt      String?
  publishedAt  DateTime?
  status       ContentStatus @default(DRAFT)
  
  pdfId        String?
  pdf          MediaAsset?   @relation("IssuePDF", fields: [pdfId], references: [id])

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@map("newsletter_issues")
}

model Page {
  id        String        @id @default(uuid())
  slug      String        @unique
  title     String
  content   Json          // Structured blocks
  status    ContentStatus @default(DRAFT)

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  @@map("pages")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   Json?
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
